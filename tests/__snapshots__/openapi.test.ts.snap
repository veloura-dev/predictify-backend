            "format": "date-time",
            "type": "string",
          },
          "id": {
            "format": "uuid",
            "type": "string",
          },
          "metadata": {
            "nullable": true,
          },
          "question": {
            "type": "string",
          },
          "status": {
            "type": "string",
          },
          "version": {
            "type": "integer",
          },
        },
        "required": [
          "id",
          "question",
          "status",
          "version",
          "createdAt",
        ],
        "type": "object",
      },
      "OpenDisputeRequest": {
        "properties": {
          "evidenceUri": {
            "format": "uri",
            "nullable": true,
            "type": "string",
          },
          "reason": {
            "maxLength": 500,
            "minLength": 10,
            "type": "string",
          },
        },
        "required": [
          "reason",
        ],
        "type": "object",
      },
      "PatchMarketRequest": {
        "properties": {
          "expectedVersion": {
            "minimum": 0,
            "type": "integer",
          },
          "metadata": {
            "nullable": true,
          },
          "question": {
            "type": "string",
          },
        },
        "required": [
